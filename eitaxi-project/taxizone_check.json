    "html": "<html lang=\"en\"><head>\n    <title>Lookup - Internet Domains</title>\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/css/slim.css\">\n\t<link rel=\"stylesheet\" type=\"text/css\" href=\"/export/system/modules/ch.SWITCH.ocms.subsite/resources/css/sub.css\"><link rel=\"stylesheet\" type=\"text/css\" media=\"all\" href=\"/export/sites/default/styles.css\"><!-- opt-stylesheet -->\n    <script async=\"\" src=\"https://tracker.switch.ch/matomo.js\"></script><script src=\"/export/system/modules/ch.SWITCH.ocms.subsite/resources/js-slim/sub-slim.js\" type=\"text/javascript\"></script><style type=\"text/css\"></style><meta name=\"description\" content=\"Check availability of .ch domain names\">    \n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta charset=\"UTF-8\">\n    <link rel=\"shortcut icon\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/favicon.ico\" type=\"image/x-icon\">\n    <link rel=\"apple-touch-icon\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/apple-touch-icon.png\">\n    <link rel=\"apple-touch-icon\" sizes=\"57x57\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/apple-touch-icon-57x57.png\">\n    <link rel=\"apple-touch-icon\" sizes=\"72x72\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/apple-touch-icon-72x72.png\">\n    <link rel=\"apple-touch-icon\" sizes=\"76x76\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/apple-touch-icon-76x76.png\">\n    <link rel=\"apple-touch-icon\" sizes=\"114x114\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/apple-touch-icon-114x114.png\">\n    <link rel=\"apple-touch-icon\" sizes=\"120x120\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/apple-touch-icon-120x120.png\">\n    <link rel=\"apple-touch-icon\" sizes=\"144x144\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/apple-touch-icon-144x144.png\">\n    <link rel=\"apple-touch-icon\" sizes=\"152x152\" href=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/site_icons/apple-touch-icon-152x152.png\">\n  </head>\n  <body>\n<div class=\"container\">\n  <div class=\"swi-subsite-logo-container\">\n    <a href=\"https://www.switch.ch/en/\"><img height=\"46\" width=\"180\" src=\"/export/system/modules/ch.SWITCH.ocms.www/resources/images/logoHi.png\" alt=\"\"></a>\n    \n    <!-- language navigation --><!--stopindex-->\n\t<ul class=\"nav nav-pills pull-right swi-nav-pills-app-meta hidden-xs\">\n       <li class=\"dropdown\">\n          <a href=\"#\" class=\"dropdown-toggle\" data-toggle=\"dropdown\">EN <span class=\"swi-link-caret\"></span></a>\n          <ul class=\"dropdown-menu\">\n          \n          <li><a href=\"/de/whois/\">DE</a></li>\n          <li><a href=\"/fr/whois/\">FR</a></li>\n          <li><a href=\"/it/whois/\">IT</a></li>\n          </ul>\n       </li>\n       \n    </ul>\n    <!--startindex-->\n    \n  </div>\n  <nav class=\"navbar navbar-default swi-navbar-subsite\" role=\"navigation\">\n    <div class=\"container-fluid\">\n      <!-- Brand and toggle get grouped for better mobile display -->\n      <div class=\"navbar-header\">\n        <button type=\"button\" class=\"navbar-toggle\" data-toggle=\"collapse\" data-target=\"#bs-example-navbar-collapse-1\">\n          <span class=\"sr-only\">Toggle navigation</span>\n          <span class=\"icon-bar\"></span>\n          <span class=\"icon-bar\"></span>\n          <span class=\"icon-bar\"></span>\n        </button>\n        <a class=\"navbar-brand\" href=\"/\">Internet Domains</a>\n      </div>\n      <!--stopindex-->\n      <div class=\"collapse navbar-collapse\" id=\"bs-example-navbar-collapse-1\">\n        <ul class=\"nav navbar-nav\">        \n\t\t  <li class=\"active \"> \n\t\t\t  <a href=\"/whois/\">Lookup